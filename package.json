{
	"name": "@kage0x3b/ebics-client",
	"version": "5.0.0",
	"description": "Node.js ISO 20022 Compliant EBICS Client (TypeScript fork with H005/EBICS 3.0 support)",
	"type": "module",
	"main": "./dist/cjs/index.cjs",
	"module": "./dist/esm/index.mjs",
	"types": "./dist/esm/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/index.d.mts",
				"default": "./dist/esm/index.mjs"
			},
			"require": {
				"types": "./dist/cjs/index.d.cts",
				"default": "./dist/cjs/index.cjs"
			}
		},
		"./OrdersH004": {
			"import": {
				"types": "./dist/esm/lib/predefinedOrders/H004/index.d.mts",
				"default": "./dist/esm/lib/predefinedOrders/H004/index.mjs"
			},
			"require": {
				"types": "./dist/cjs/lib/predefinedOrders/H004/index.d.cts",
				"default": "./dist/cjs/lib/predefinedOrders/H004/index.cjs"
			}
		},
		"./OrdersH005": {
			"import": {
				"types": "./dist/esm/lib/predefinedOrders/H005/index.d.mts",
				"default": "./dist/esm/lib/predefinedOrders/H005/index.mjs"
			},
			"require": {
				"types": "./dist/cjs/lib/predefinedOrders/H005/index.d.cts",
				"default": "./dist/cjs/lib/predefinedOrders/H005/index.cjs"
			}
		}
	},
	"files": [
		"dist/**/*",
		"templates/**/*"
	],
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsdown",
		"type-check": "tsc -p tsconfig.test.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "mocha",
		"test:types": "tsd",
		"verify:diff": "node scripts/verify-diff.mjs",
		"verify": "pnpm type-check && pnpm lint && pnpm test && pnpm build && pnpm test:types",
		"prepack": "pnpm build",
		"version": "auto-changelog -p -t changelog-template.hbs && git add CHANGELOG.md"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Kage0x3B/node-ebics-client.git"
	},
	"bugs": {
		"url": "https://github.com/Kage0x3B/node-ebics-client/issues"
	},
	"homepage": "https://github.com/Kage0x3B/node-ebics-client#readme",
	"keywords": [
		"EBICS",
		"ISO20022",
		"nodejs",
		"api",
		"banking"
	],
	"author": "eCollect Sofia Tech Team",
	"contributors": [
		{
			"name": "Dimitar Nanov",
			"url": "https://nanov.io",
			"email": "dimitar@nanov.io"
		},
		{
			"name": "Vladislav Hristov",
			"url": "https://github.com/vladhristov",
			"email": "vlad.s.ch@gmail.com"
		},
		{
			"name": "Vasyl Stashuk",
			"url": "https://github.com/vasyas"
		},
		{
			"name": "Yago",
			"url": "https://github.com/yagop"
		},
		{
			"name": "Herman van Hazendonk",
			"email": "github.com@herrie.org"
		},
		{
			"name": "chrwoizi",
			"url": "https://github.com/chrwoizi"
		},
		{
			"name": "Herrie",
			"url": "https://github.com/Herrie82"
		},
		{
			"name": "Maik Marschner ",
			"url": "https://github.com/leMaik"
		},
		{
			"name": "Moritz Hein",
			"email": "moritz.hein@live.de",
			"url": "https://moritz.website"
		}
	],
	"license": "MIT",
	"dependencies": {
		"@xmldom/xmldom": "^0.8.10",
		"handlebars": "^4.7.8",
		"js2xmlparser": "^5.0.0",
		"node-forge": "^1.3.1",
		"node-rsa": "^1.1.1",
		"rock-req": "^5.1.3",
		"uuid": "^9.0.1",
		"xml-crypto": "^6.0.0",
		"xpath": "0.0.32"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/chai": "^4.3.20",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@types/node-forge": "^1.3.14",
		"@types/node-rsa": "^1.1.4",
		"@types/uuid": "^9.0.8",
		"@types/xml-crypto": "^1.4.6",
		"auto-changelog": "^2.4.0",
		"chai": "^4.5.0",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"mocha": "^11.7.5",
		"prettier": "^3.8.3",
		"tsd": "^0.33.0",
		"tsdown": "^0.22.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"xmllint-wasm": "^4.0.2"
	},
	"tsd": {
		"directory": "test/types"
	}
}
